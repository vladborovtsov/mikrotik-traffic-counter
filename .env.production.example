APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC

DB_DRIVER=sqlite
DB_SQLITE_PATH=var/database/tikstats.sqlite

DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=tikstats
DB_MYSQL_USERNAME=tikstats
DB_MYSQL_PASSWORD=replace_me

AUTH_ENABLED=true
AUTH_TOKEN=replace_me

SOURCE_IP_ENABLED=false
SOURCE_IP_ALLOWLIST=127.0.0.1,::1

TRAFFIC_USE_DELTA=true
DEFAULT_WINDOW_HOURS=48
